import re


# Base class
class Account:

    def __init__(self, account_number, balance):
        self.__balance = balance
        self.account_number = account_number

    # Encapsulation using getter
    def get_balance(self):
        return self.__balance

    def deposit(self, amount):
        self.__balance += amount
        print("Amount deposited successfully.")

    def withdraw(self, amount):
        if amount <= self.__balance:
            self.__balance -= amount
            print("Withdrawal successful.")
        else:
            print("Insufficient balance.")


# Child class - Savings Account
class SavingsAccount(Account):

    def withdraw(self, amount):
        if amount <= self.get_balance():
            super().withdraw(amount)
        else:
            print("Savings account: Not enough balance.")


# Child class - Current Account
class CurrentAccount(Account):

    def withdraw(self, amount):
        if amount <= self.get_balance() + 500:
            super().withdraw(amount)
        else:
            print("Current account: Overdraft limit exceeded.")


# Validate account number using regex
def validate_account(account_number):

    pattern = r"^[0-9]{10}$"

    if re.match(pattern, account_number):
        return True
    else:
        return False


# Main program

print("===== Bank Account System =====")

acc_no = input("Enter 10 digit account number: ")

if validate_account(acc_no):

    print("Account number valid.")

    account_type = input("Enter account type (Savings/Current): ")

    balance = float(input("Enter initial balance: "))


    if account_type.lower() == "savings":
        account = SavingsAccount(acc_no, balance)

    elif account_type.lower() == "current":
        account = CurrentAccount(acc_no, balance)

    else:
        print("Invalid account type.")
        exit()


    while True:

        print("\n1. Check Balance")
        print("2. Deposit")
        print("3. Withdraw")
        print("4. Exit")

        choice = input("Enter choice: ")


        if choice == "1":

            print("Balance:", account.get_balance())


        elif choice == "2":

            amount = float(input("Enter deposit amount: "))
            account.deposit(amount)


        elif choice == "3":

            amount = float(input("Enter withdraw amount: "))
            account.withdraw(amount)


        elif choice == "4":

            print("Thank you for using Bank System.")
            break


        else:

            print("Invalid choice.")

else:

    print("Invalid account number.")
