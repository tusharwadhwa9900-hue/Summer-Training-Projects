import random
import string


# Custom exception
class PasswordError(Exception):
    pass


# Generate password function
def generate_password():
    characters = string.ascii_letters + string.digits + string.punctuation

    password = ""

    for i in range(10):
        password = password + random.choice(characters)

    return password


# Validate password function
def validate_password(password):
    if len(password) < 8:
        raise PasswordError("Password must be at least 8 characters long.")

    if not any(char.isupper() for char in password):
        raise PasswordError("Password must contain an uppercase letter.")

    if not any(char.islower() for char in password):
        raise PasswordError("Password must contain a lowercase letter.")

    if not any(char.isdigit() for char in password):
        raise PasswordError("Password must contain a number.")

    if not any(char in string.punctuation for char in password):
        raise PasswordError("Password must contain a special character.")

    return True


# Main program
while True:
    print("\n===== Password Generator & Validator =====")
    print("1. Generate Password")
    print("2. Validate Password")
    print("3. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        password = generate_password()
        print("Generated Password:", password)

    elif choice == "2":
        password = input("Enter password to check: ")

        try:
            validate_password(password)
            print("Password is strong and valid.")

        except PasswordError as e:
            print("Invalid Password:", e)

    elif choice == "3":
        print("Exiting Program...")
        break

    else:
        print("Invalid choice.")
